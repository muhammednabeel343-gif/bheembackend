# Backend environment settings for Project Bheem
# Copy this file to .env and update values for your environment.
DATABASE_URL=mysql+pymysql://root:password@localhost/projectbheem
# For MySQL, use a connection string like:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/project_bheem
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
